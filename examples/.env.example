# QMill circuit compression external example configuration

# Required
QAS_BASE_URL=https://qas.qmill.com
# Authenticate with CLI before running examples:
#   qas auth login --base-url "$QAS_BASE_URL"

# Optional compression overrides
# QAS_NUM_GPUS=1
# QAS_ITERATION_MINUTES=45
# QAS_GATE_SET=CX_RX_RZ
# QAS_HPC_MODE=lumi_v2_0

# Optional polling controls for API examples
# QAS_POLL_INTERVAL=5
# QAS_POLL_TIMEOUT=300
